# ----- Database (Supabase Postgres) -----
# Pooled connection (pgBouncer, port 6543) — used at runtime by the app.
# Append ?pgbouncer=true&connection_limit=1 for serverless.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# ----- Auth (NextAuth v5) -----
# Generate with: openssl rand -base64 32  (use a fresh value in production)
AUTH_SECRET=""
# Production: https://your-domain.com   Local: http://localhost:3000
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated list of allowed sign-in email domains.
ALLOWED_EMAIL_DOMAINS="princeton.edu"
# Email that gets bootstrapped to the TREASURER role on first sign-in.
INITIAL_TREASURER_EMAIL=""

# ----- Receipt storage (Supabase Storage) -----
# Without these, receipts fall back to the local filesystem (won't persist on Vercel).
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_RECEIPTS_BUCKET="receipts"

# ----- Optional: receipt OCR -----
# When set, uploads are auto-parsed (date/amount/description) via OpenAI Vision.
OPENAI_API_KEY=""
