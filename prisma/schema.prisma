generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TREASURER
  OFFICER
}

enum PaymentMethod {
  CHECK
  WIRE_TRANSFER
  CREDIT_CARD
  VENMO
  CASH
  OTHER
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  PAID
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  role           Role            @default(OFFICER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  reimbursements Reimbursement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Semester {
  id                 String            @id @default(cuid())
  name               String
  startDate          DateTime
  endDate            DateTime?
  totalBudget        Float             @default(0)
  isActive           Boolean           @default(false)
  openingBankBalance Float             @default(0)
  openingUndeposited Float             @default(0)
  previousSemesterId String?
  previousSemester   Semester?         @relation("SemesterCarryover", fields: [previousSemesterId], references: [id])
  nextSemesters      Semester[]        @relation("SemesterCarryover")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  categories         BudgetCategory[]
  weeks              Week[]
  expenses           Expense[]
  checks             Check[]
  deposits           Deposit[]
  reconciliations    BankReconciliation[]
  venmoIncomes       VenmoIncome[]
  events             Event[]
}

model BudgetCategory {
  id              String          @id @default(cuid())
  semesterId      String
  name            String
  allocatedAmount Float           @default(0)
  sortOrder       Int             @default(0)
  semester        Semester        @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  checks          Check[]
  reimbursements  Reimbursement[]

  @@unique([semesterId, name])
}

model Week {
  id         String        @id @default(cuid())
  semesterId String
  weekNumber Int
  startDate  DateTime
  label      String?
  semester   Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  expenses   Expense[]
  venmoIncomes VenmoIncome[]
  events     Event[]

  @@unique([semesterId, weekNumber])
}

model Expense {
  id            String        @id @default(cuid())
  semesterId    String
  categoryId    String
  weekId        String?
  eventId       String?
  amount        Float
  description   String
  date          DateTime
  paymentMethod PaymentMethod @default(CHECK)
  checkId       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  semester      Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  week          Week?         @relation(fields: [weekId], references: [id])
  event         Event?        @relation(fields: [eventId], references: [id])
  check         Check?        @relation(fields: [checkId], references: [id])
}

model Check {
  id            String         @id @default(cuid())
  semesterId    String
  checkNumber   String
  description   String
  amount        Float
  date          DateTime
  recipientName String
  categoryId    String?
  eventId       String?
  paymentMethod PaymentMethod  @default(CHECK)
  cleared       Boolean        @default(false)
  clearedDate   DateTime?
  isCarryover   Boolean        @default(false)
  memo          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  semester      Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  category      BudgetCategory? @relation(fields: [categoryId], references: [id])
  event         Event?         @relation(fields: [eventId], references: [id])
  expenses      Expense[]
  reimbursements Reimbursement[]
}

model Reimbursement {
  id          String              @id @default(cuid())
  officerId   String
  semesterId  String
  name        String
  amount      Float
  date        DateTime
  categoryId  String?
  eventId     String?
  tags        String?
  notes       String?
  receiptUrl  String?
  parsedData  String?
  status      ReimbursementStatus @default(PENDING)
  checkId     String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  officer     User                @relation(fields: [officerId], references: [id])
  category    BudgetCategory?     @relation(fields: [categoryId], references: [id])
  event       Event?              @relation(fields: [eventId], references: [id])
  check       Check?              @relation(fields: [checkId], references: [id])
}

model Deposit {
  id         String   @id @default(cuid())
  semesterId String
  amount     Float
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model BankReconciliation {
  id            String   @id @default(cuid())
  semesterId    String
  date          DateTime @default(now())
  actualBalance Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  semester      Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model VenmoIncome {
  id          String   @id @default(cuid())
  semesterId  String
  amount      Float
  date        DateTime
  description String
  eventName   String?
  weekId      String?
  createdAt   DateTime @default(now())
  semester    Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  week        Week?    @relation(fields: [weekId], references: [id])
}

model Event {
  id              String          @id @default(cuid())
  semesterId      String
  weekId          String?
  name            String
  date            DateTime
  time            String?
  eventType       String?
  audience        String?
  notes           String?
  isInformational Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  semester        Semester        @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  week            Week?           @relation(fields: [weekId], references: [id])
  expenses        Expense[]
  checks          Check[]
  reimbursements  Reimbursement[]

  @@unique([semesterId, date, name])
}
